---
import AnimatedBackground from '../components/AnimatedBackground.astro';
import FloatingIcons from '../components/FloatingIcons.astro';
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalUrl?: string; // pakai ini kalau artikel juga tayang di media lain
  pubDate?: Date;
  updatedDate?: Date;
  isArticle?: boolean;
}

const {
  title,
  description,
  image = '/og-default.jpg',
  canonicalUrl,
  pubDate,
  updatedDate,
  isArticle = false,
} = Astro.props;

const canonical = canonicalUrl ?? new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL(image, Astro.site).toString();
const siteName = 'Muhammad Nur Hadi';

// JSON-LD structured data - bikin Google lebih ngerti konten kamu
const jsonLd = isArticle
  ? {
      '@context': 'https://schema.org',
      '@type': 'Article',
      headline: title,
      description,
      image: ogImage,
      datePublished: pubDate?.toISOString(),
      dateModified: (updatedDate ?? pubDate)?.toISOString(),
      author: { '@type': 'Person', name: siteName },
    }
  : {
      '@context': 'https://schema.org',
      '@type': 'Person',
      name: siteName,
      url: Astro.site?.toString(),
    };
---
<!doctype html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  
  <!-- Fonts: Inter, Sora (from portfolio design) -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Sora:wght@600;700&display=swap" rel="stylesheet">
  
  <!-- Global CSS (imported in frontmatter) -->

  <title>{title} | {siteName}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <!-- Open Graph / Facebook / LinkedIn -->
  <meta property="og:type" content={isArticle ? 'article' : 'website'} />
  <meta property="og:url" content={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:site_name" content={siteName} />

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- RSS autodiscovery -->
  <link rel="alternate" type="application/rss+xml" title={siteName} href="/rss.xml" />

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</head>
<body>
  <AnimatedBackground />
  <FloatingIcons opacity={0.6} iconSize={36} />
  
  <header class="site-header">
    <nav class="nav-container">
      <span class="logo-text">
        MNH Portofolio
      </span>
      <ul class="nav-links-list">
        <li>
          <a href="/" class="nav-link-item" data-page="home">
            Home
            <span class="nav-underline"></span>
          </a>
        </li>
        <li>
          <a href="/blog" class="nav-link-item" data-page="blog">
            Blog
            <span class="nav-underline"></span>
          </a>
        </li>
        <li>
          <a href="/about-me" class="nav-link-item" data-page="about">
            About
            <span class="nav-underline"></span>
          </a>
        </li>
        <li>
          <a href="https://mnurhadi-porto.vercel.app/" target="_blank" rel="noopener" class="nav-link-item">
            Portfolio
            <span class="nav-underline"></span>
          </a>
        </li>
        <li>
          <button id="theme-toggle" type="button" class="theme-toggle" aria-label="Toggle dark mode">
            <svg class="sun-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="5"></circle>
              <line x1="12" y1="1" x2="12" y2="3"></line>
              <line x1="12" y1="21" x2="12" y2="23"></line>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
              <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
              <line x1="1" y1="12" x2="3" y2="12"></line>
              <line x1="21" y1="12" x2="23" y2="12"></line>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
              <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
            </svg>
            <svg class="moon-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
            </svg>
          </button>
        </li>
      </ul>
    </nav>
  </header>

  <main class="site-main">
    <slot />
  </main>

  <footer class="site-footer">
    <p class="footer-copy">© 2026 Muhammad Nur Hadi · Malang, East Java, Indonesia</p>
    <p class="footer-sub">Built with Astro + TypeScript + Tailwind CSS</p>
  </footer>

  <script>
    // ── Active nav link ───────────────────────────
    const path = window.location.pathname;
    document.querySelectorAll('.nav-link-item[data-page]').forEach((link) => {
      const page = link.getAttribute('data-page');
      const isActive =
        (page === 'home'  && (path === '/' || path === '')) ||
        (page === 'blog'  && path.startsWith('/blog')) ||
        (page === 'about' && path.startsWith('/about'));
      if (isActive) link.classList.add('active');
    });

    // ── Theme toggle ──────────────────────────────
    const themeToggle = document.getElementById('theme-toggle');
    const html = document.documentElement;

    const savedTheme = localStorage.getItem('theme') || 'light';
    const applyTheme = (theme) => {
      if (theme === 'dark') {
        html.classList.add('dark');
        html.dataset.theme = 'dark';
        if (themeToggle) themeToggle.setAttribute('aria-pressed', 'true');
      } else {
        html.classList.remove('dark');
        html.dataset.theme = 'light';
        if (themeToggle) themeToggle.setAttribute('aria-pressed', 'false');
      }
    };

    applyTheme(savedTheme);

    document.addEventListener('click', (e) => {
      const el = e.target instanceof Element ? e.target.closest('#theme-toggle') : null;
      if (el) {
        const isDark = html.classList.toggle('dark');
        const newTheme = isDark ? 'dark' : 'light';
        localStorage.setItem('theme', newTheme);
        applyTheme(newTheme);
      }
    });
  </script>

  <style>
    body {
      font-family: 'Inter', sans-serif;
    }

    /* ─── HEADER ─────────────────────────────────── */
    .site-header {
      position: sticky;
      top: 0;
      z-index: 50;
      background: rgba(9, 9, 11, 0.8); /* bg-zinc-950/80 */
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      border-bottom: 1px solid #27272a; /* border-zinc-800 */
      height: 4rem; /* h-16 */
      display: flex;
      align-items: center;
      animation: slideDown 0.5s ease-out both;
    }

    :global(html:not(.dark)) .site-header {
      background: rgba(255, 255, 255, 0.8);
      border-bottom: 1px solid #e4e4e7; /* border-zinc-200 */
    }

    @keyframes slideDown {
      from { transform: translateY(-20px); opacity: 0; }
      to   { transform: translateY(0); opacity: 1; }
    }

    .nav-container {
      width: 100%;
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 1.5rem; /* px-6 */
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    @media (min-width: 768px) {
      .nav-container {
        padding: 0 2.5rem; /* md:px-10 */
      }
    }

    .logo-text {
      font-family: 'Sora', sans-serif;
      font-weight: 800; /* font-extrabold */
      font-size: 1.125rem; /* text-lg */
      letter-spacing: -0.025em; /* tracking-tight */
      color: #ffffff; /* text-white */
      transition: opacity 0.3s ease;
    }

    :global(html:not(.dark)) .logo-text {
      color: #09090b; /* text-zinc-950 */
    }

    .nav-links-list {
      display: flex;
      align-items: center;
      gap: 1.5rem; /* gap-6 */
      list-style: none;
      margin: 0;
      padding: 0;
    }

    @media (min-width: 768px) {
      .nav-links-list {
        gap: 2rem; /* md:gap-8 */
      }
    }

    .nav-link-item {
      color: #a1a1aa; /* text-zinc-400 */
      text-decoration: none;
      font-size: 0.875rem; /* text-sm */
      font-weight: 500; /* font-medium */
      transition: color 0.3s ease;
      position: relative;
      padding: 0.25rem 0;
    }

    .nav-link-item:hover,
    .nav-link-item.active {
      color: #ffffff; /* hover:text-white */
    }

    :global(html:not(.dark)) .nav-link-item {
      color: #71717a; /* text-zinc-500 */
    }

    :global(html:not(.dark)) .nav-link-item:hover,
    :global(html:not(.dark)) .nav-link-item.active {
      color: #09090b; /* hover:text-zinc-950 */
    }

    /* Line Indicator (group-hover:w-full) */
    .nav-underline {
      position: absolute;
      left: 0;
      bottom: 0;
      width: 0;
      height: 2px;
      background-color: #ffffff; /* bg-white */
      transition: width 0.3s ease;
    }

    :global(html:not(.dark)) .nav-underline {
      background-color: #09090b;
    }

    .nav-link-item:hover .nav-underline,
    .nav-link-item.active .nav-underline {
      width: 100%;
    }

    /* Toggle theme button */
    .theme-toggle {
      background: transparent;
      border-radius: 9999px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.3s ease;
      color: #ffffff;
      border: 1px solid #27272a;
      width: 36px;
      height: 36px;
      position: relative;
      overflow: hidden;
    }

    :global(html:not(.dark)) .theme-toggle {
      color: #09090b;
      border-color: #e4e4e7;
    }

    .theme-toggle:hover {
      background: rgba(255, 255, 255, 0.08);
      border-color: #a1a1aa;
    }

    :global(html:not(.dark)) .theme-toggle:hover {
      background: rgba(9, 9, 11, 0.05);
      border-color: #71717a;
    }

    .sun-icon,
    .moon-icon {
      position: absolute;
      transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.5s ease;
    }

    :global(html:not(.dark)) .sun-icon { opacity: 1; transform: rotate(0deg) scale(1); }
    :global(html:not(.dark)) .moon-icon { opacity: 0; transform: rotate(90deg) scale(0); }
    :global(html.dark) .sun-icon { opacity: 0; transform: rotate(-90deg) scale(0); }
    :global(html.dark) .moon-icon { opacity: 1; transform: rotate(0deg) scale(1); }

    /* ─── MAIN ───────────────────────────────────── */
    .site-main {
      max-width: 100%;
      margin: 0;
      padding: 0;
      min-height: calc(100vh - 16rem);
      position: relative;
      z-index: 10;
    }

    /* ─── FOOTER ─── */
    .site-footer {
      position: relative;
      z-index: 10;
      background-color: #09090b; /* bg-zinc-950 */
      border-top: 1px solid #27272a; /* border-zinc-800 */
      color: #71717a; /* text-zinc-500 */
      text-align: center;
      padding: 3rem 1.5rem; /* py-12 px-6 */
    }

    :global(html:not(.dark)) .site-footer {
      background-color: #f4f4f5; /* bg-zinc-100 */
      border-top: 1px solid #e4e4e7; /* border-zinc-200 */
      color: #71717a;
    }

    .footer-copy {
      font-size: 0.875rem; /* text-sm */
      margin: 0 0 0.5rem;
    }

    .footer-sub {
      font-size: 0.75rem; /* text-xs */
      color: #52525b; /* text-zinc-600 */
      margin: 0;
    }

    :global(html:not(.dark)) .footer-sub {
      color: #a1a1aa; /* text-zinc-400 */
    }

    /* ─── RESPONSIVE ─────────────────────────────── */
    @media (max-width: 768px) {
      .nav-links-list {
        gap: 0.75rem;
      }

      .nav-link-item {
        font-size: 0.8125rem;
        padding: 0.25rem 0.25rem;
      }

      .site-main {
        padding: 1.5rem 1rem;
      }
    }
  </style>
</body>
</html>
