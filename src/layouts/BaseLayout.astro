---
import AnimatedBackground from '../components/AnimatedBackground.astro';
import FloatingIcons from '../components/FloatingIcons.astro';
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalUrl?: string; // pakai ini kalau artikel juga tayang di media lain
  pubDate?: Date;
  updatedDate?: Date;
  isArticle?: boolean;
  preloadImage?: string;
  preloadSrcset?: string;
  preloadSizes?: string;
}

const {
  title,
  description,
  image = '/og-default.jpg',
  canonicalUrl,
  pubDate,
  updatedDate,
  isArticle = false,
  preloadImage,
  preloadSrcset,
  preloadSizes,
} = Astro.props;

const canonical = canonicalUrl ?? new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL(image, Astro.site).toString() + '?v=2';
const siteName = 'Muhammad Nur Hadi';

// JSON-LD structured data - bikin Google lebih ngerti konten kamu
const jsonLd = isArticle
  ? {
      '@context': 'https://schema.org',
      '@type': 'Article',
      headline: title,
      description,
      image: ogImage,
      datePublished: pubDate?.toISOString(),
      dateModified: (updatedDate ?? pubDate)?.toISOString(),
      author: { '@type': 'Person', name: siteName },
    }
  : {
      '@context': 'https://schema.org',
      '@type': 'Person',
      name: siteName,
      url: Astro.site?.toString(),
    };
---
<!doctype html>
<html lang="id">
<head>
  <meta name="google-site-verification" content="XKxPBToqCOOdcG7BfuV_9CaxWSMBZ1CedyislvHBWFM" />
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/mnh-mark.svg" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  
  <!-- Sora (LCP font — HIGHEST priority, preloaded before Inter) -->
  <link rel="preload" href="/fonts/sora-700.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/fonts/sora-600.woff2" as="font" type="font/woff2" crossorigin>
  <!-- Inter (body font) -->
  <link rel="preload" href="/fonts/inter-400.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/fonts/inter-600.woff2" as="font" type="font/woff2" crossorigin>

  <!-- fonts.css: loaded non-blocking (same pattern as animations.css) -->
  <!-- @font-face for Sora is inlined below for article pages to avoid any blocking -->
  <link rel="stylesheet" href="/fonts.css" media="print" onload="this.media='all'">
  <noscript><link rel="stylesheet" href="/fonts.css"></noscript>

  <!-- Non-critical CSS (animations) - loaded after initial paint -->
  <link rel="stylesheet" href="/animations.css" media="print" onload="this.media='all'">
  <noscript><link rel="stylesheet" href="/animations.css"></noscript>

  <!-- CRITICAL INLINE CSS for article pages -->
  <!-- Inlined to let H1.article-title render immediately, without waiting for any external CSS -->
  {isArticle && (
    <style>
      /* Inline @font-face for Sora — browser knows the font immediately,
         even before fonts.css (now non-blocking) is downloaded */
      @font-face {
        font-family: 'Sora';
        font-style: normal;
        font-weight: 600;
        font-display: swap;
        src: url('/fonts/sora-600.woff2') format('woff2');
        size-adjust: 98%;
        ascent-override: 90%;
        descent-override: 22%;
        line-gap-override: 0%;
      }
      @font-face {
        font-family: 'Sora';
        font-style: normal;
        font-weight: 700;
        font-display: swap;
        src: url('/fonts/sora-700.woff2') format('woff2');
        size-adjust: 98%;
        ascent-override: 90%;
        descent-override: 22%;
        line-gap-override: 0%;
      }
      /* Critical CSS: LCP element (.article-title) */
      /* All properties needed for immediate first paint of H1 */
      .article-title {
        font-family: 'Sora', system-ui, sans-serif;
        font-size: 2.5rem;
        font-weight: 700;
        line-height: 1.15;
        margin: 0 0 1rem 0;
        background: linear-gradient(135deg, #3b82f6, #8b5cf6);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      html:not(.dark) .article-title {
        background: linear-gradient(135deg, #1d4ed8, #7c3aed);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      @media (max-width: 768px) {
        .article-title { font-size: 2rem; }
      }
    </style>
  )}

  <!-- Preload LCP image for article pages -->
  {isArticle && preloadSrcset && preloadSizes && (
    <link rel="preload" as="image" fetchpriority="high" imagesrcset={preloadSrcset} imagesizes={preloadSizes} />
  )}
  {isArticle && preloadImage && !preloadSrcset && (
    <link rel="preload" as="image" fetchpriority="high" href={preloadImage} />
  )}

  <!-- Global CSS (imported in frontmatter) -->

  <title>{title} | {siteName}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <!-- Open Graph / Facebook / LinkedIn -->
  <meta property="og:type" content={isArticle ? 'article' : 'website'} />
  <meta property="og:url" content={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:type" content="image/jpeg" />
  <meta property="og:site_name" content={siteName} />

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- RSS autodiscovery -->
  <link rel="alternate" type="application/rss+xml" title={siteName} href="/rss.xml" />

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- Google tag (gtag.js) - placed at the end of head to prevent blocking critical CSS/LCP preloads -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=AW-18335228478"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());

    gtag('config', 'AW-18335228478');
  </script>
</head>
<body>
  <AnimatedBackground />
  <FloatingIcons opacity={0.6} iconSize={36} />
  
  <header class="site-header">
    <span class="logo-text">MNH</span>
    <ul class="nav-links-list">
      <li>
        <a href="/" class="nav-link-item" data-page="home">
          Home
          <span class="nav-underline"></span>
        </a>
      </li>
      <li>
        <a href="/blog" class="nav-link-item" data-page="blog">
          Blog
          <span class="nav-underline"></span>
        </a>
      </li>
      <li>
        <a href="/about-me" class="nav-link-item" data-page="about">
          About
          <span class="nav-underline"></span>
        </a>
      </li>
      <li>
        <a href="https://mnurhadi-porto.vercel.app/" target="_blank" rel="noopener" class="nav-link-item">
          Portfolio
          <span class="nav-underline"></span>
        </a>
      </li>
      <li>
        <button id="theme-toggle" type="button" class="theme-toggle" aria-label="Toggle dark mode">
          <svg class="sun-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="5"></circle>
            <line x1="12" y1="1" x2="12" y2="3"></line>
            <line x1="12" y1="21" x2="12" y2="23"></line>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
            <line x1="1" y1="12" x2="3" y2="12"></line>
            <line x1="21" y1="12" x2="23" y2="12"></line>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
          </svg>
          <svg class="moon-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
          </svg>
        </button>
      </li>
    </ul>
  </header>

  <main class="site-main">
    <slot />
  </main>

  <footer class="site-footer">
    <p class="footer-copy">© 2026 Muhammad Nur Hadi · Malang, East Java, Indonesia</p>
    <p class="footer-sub">Built with Astro + TypeScript + Tailwind CSS</p>
  </footer>

  <script>
    // ── Active nav link ───────────────────────────
    // Batch DOM reads first, then writes to avoid forced reflow
    const path = window.location.pathname;
    const navLinks = document.querySelectorAll('.nav-link-item[data-page]');
    const activeLinks = [];

    // Read phase: collect all data
    navLinks.forEach((link) => {
      const page = link.getAttribute('data-page');
      const isActive =
        (page === 'home'  && (path === '/' || path === '')) ||
        (page === 'blog'  && path.startsWith('/blog')) ||
        (page === 'about' && path.startsWith('/about'));
      if (isActive) activeLinks.push(link);
    });

    // Write phase: apply all changes at once
    requestAnimationFrame(() => {
      activeLinks.forEach((link) => link.classList.add('active'));
    });

    // ── Theme toggle ──────────────────────────────
    const themeToggle = document.getElementById('theme-toggle');
    const html = document.documentElement;

    const savedTheme = localStorage.getItem('theme') || 'light';
    const applyTheme = (theme) => {
      // Batch DOM writes to avoid forced reflow
      if (theme === 'dark') {
        html.classList.add('dark');
        html.dataset.theme = 'dark';
        if (themeToggle) themeToggle.setAttribute('aria-pressed', 'true');
      } else {
        html.classList.remove('dark');
        html.dataset.theme = 'light';
        if (themeToggle) themeToggle.setAttribute('aria-pressed', 'false');
      }
    };

    // Apply theme before any DOM reads to prevent layout thrashing
    applyTheme(savedTheme);

    document.addEventListener('click', (e) => {
      const el = e.target instanceof Element ? e.target.closest('#theme-toggle') : null;
      if (el) {
        // Use requestAnimationFrame to batch DOM operations
        requestAnimationFrame(() => {
          const isDark = html.classList.toggle('dark');
          const newTheme = isDark ? 'dark' : 'light';
          localStorage.setItem('theme', newTheme);
          applyTheme(newTheme);
        });
      }
    });
  </script>

  <style>
    body {
      font-family: 'Inter', sans-serif;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* ─── HEADER ─────────────────────────────────── */
    .site-header {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 50;
      background: var(--bg-header);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      border-bottom: 1px solid var(--border-color);
      height: 4rem; /* h-16 */
      padding: 0 1.5rem; /* px-6 */
      display: flex;
      align-items: center;
      justify-content: space-between;
      animation: slideDown 0.5s ease-out both;
      transition: background-color 0.3s ease;
    }

    @media (min-width: 768px) {
      .site-header {
        padding: 0 2.5rem; /* md:px-10 */
      }
    }

    @keyframes slideDown {
      from { transform: translateY(-20px); opacity: 0; }
      to   { transform: translateY(0); opacity: 1; }
    }

    .logo-text {
      font-family: 'Sora', sans-serif;
      font-weight: 800; /* font-extrabold */
      font-size: 1.125rem; /* text-lg */
      letter-spacing: -0.025em; /* tracking-tight */
      color: var(--text-primary);
      transition: opacity 0.3s ease;
    }

    .nav-links-list {
      display: flex;
      align-items: center;
      gap: 1.5rem; /* gap-6 */
      list-style: none;
      margin: 0;
      padding: 0;
    }

    @media (min-width: 768px) {
      .nav-links-list {
        gap: 2rem; /* md:gap-8 */
      }
    }

    .nav-link-item {
      color: var(--text-secondary);
      text-decoration: none;
      font-size: 0.875rem; /* text-sm */
      font-weight: 500; /* font-medium */
      transition: color 0.3s ease;
      position: relative;
    }

    .nav-link-item:hover,
    .nav-link-item.active {
      color: var(--text-primary);
    }

    /* Line Indicator - matches Layout.tsx: bg-gradient-to-r from-blue-500 to-emerald-500 */
    .nav-underline {
      position: absolute;
      left: 0;
      bottom: 0;
      width: 0;
      height: 0.5px;
      background: linear-gradient(to right, var(--accent-1), var(--accent-2));
      transition: width 0.3s ease;
    }

    .nav-link-item:hover .nav-underline,
    .nav-link-item.active .nav-underline {
      width: 100%;
    }

    /* Toggle theme button - matches Layout.tsx: p-2 rounded-full bg-secondary border border-color hover:scale-110 */
    .theme-toggle {
      background: var(--bg-secondary);
      border-radius: 9999px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: transform 0.2s ease, background 0.3s ease;
      color: var(--text-primary);
      border: 1px solid var(--border-color);
      padding: 0.5rem;
      width: 36px;
      height: 36px;
      position: relative;
      overflow: hidden;
    }

    .theme-toggle:hover {
      transform: scale(1.1);
    }

    .sun-icon,
    .moon-icon {
      position: absolute;
      transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.5s ease;
    }

    :global(html:not(.dark)) .sun-icon { opacity: 1; transform: rotate(0deg) scale(1); }
    :global(html:not(.dark)) .moon-icon { opacity: 0; transform: rotate(90deg) scale(0); }
    :global(html.dark) .sun-icon { opacity: 0; transform: rotate(-90deg) scale(0); }
    :global(html.dark) .moon-icon { opacity: 1; transform: rotate(0deg) scale(1); }

    /* ─── MAIN ───────────────────────────────────── */
    .site-main {
      max-width: 100%;
      margin: 0;
      padding: 0;
      flex: 1;
      position: relative;
      z-index: 10;
    }

    /* ─── FOOTER ─── matches Layout.tsx: bgSecondary border-t borderColor textSecondary text-center py-12 px-6 */
    .site-footer {
      position: relative;
      z-index: 10;
      background-color: var(--bg-secondary);
      border-top: 1px solid var(--border-color);
      color: var(--text-secondary);
      text-align: center;
      padding: 3rem 1.5rem; /* py-12 px-6 */
    }

    .footer-copy {
      font-size: 0.875rem; /* text-sm */
      margin: 0 0 0.5rem;
      color: var(--text-secondary);
    }

    .footer-sub {
      font-size: 0.75rem; /* text-xs */
      color: var(--text-secondary);
      margin: 0;
    }

    /* ─── RESPONSIVE ─────────────────────────────── */
    @media (max-width: 768px) {
      .nav-links-list {
        gap: 0.75rem;
      }

      .nav-link-item {
        font-size: 0.8125rem;
        padding: 0.25rem 0.25rem;
      }

      .site-main {
        padding: 1.5rem 1rem;
      }
    }
  </style>
</body>
</html>
