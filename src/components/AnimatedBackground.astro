---
/**
 * AnimatedBackground - Match portfolio AnimatedBackground.tsx exactly
 * Styles moved to external CSS for non-blocking load
 */
---

<div class="animated-background">
  <!-- Noise Texture Overlay -->
  <div class="noise-overlay"></div>

  <!-- Animated Gradient Bubbles (matches portfolio DARK_COLORS) -->
  <div class="bubble bubble-1"></div>
  <div class="bubble bubble-2"></div>
  <div class="bubble bubble-3"></div>
  <div class="bubble bubble-4"></div>
  <div class="bubble bubble-5"></div>
  <div class="bubble bubble-6"></div>

  <!-- Dot Grid (matches DotGrid.tsx spacing=24, radius=1.5, opacity=0.25) -->
  <svg class="dot-grid" aria-hidden="true">
    <defs>
      <pattern id="dot-grid" x="0" y="0" width="24" height="24" patternUnits="userSpaceOnUse">
        <circle cx="12" cy="12" r="1.5" fill="currentColor" />
      </pattern>
    </defs>
    <rect width="100%" height="100%" fill="url(#dot-grid)" />
  </svg>

  <!-- Floating Geometric Shapes (matches portfolio shapes) -->
  <div class="shape shape-circle-1"></div>
  <div class="shape shape-circle-2"></div>
  <div class="shape shape-circle-3"></div>
  <div class="shape shape-square-1"></div>
  <div class="shape shape-square-2"></div>
  <div class="shape shape-triangle-1"></div>
  <div class="shape shape-triangle-2"></div>
  <div class="shape shape-triangle-3"></div>

  <!-- Subtle Grid Pattern (matches portfolio) -->
  <div class="grid-pattern"></div>
</div>
