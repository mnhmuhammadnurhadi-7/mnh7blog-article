---
/**
 * AnimatedBackground - Background animasi dengan gradient dan floating elements
 * Diadaptasi dari React portfolio untuk Astro
 */
---

<div class="animated-background">
  <div class="gradient-orb orb-1"></div>
  <div class="gradient-orb orb-2"></div>
  <div class="gradient-orb orb-3"></div>
  <div class="gradient-orb orb-4"></div>
  
  <!-- SVG patterns -->
  <svg class="svg-pattern pattern-1" viewBox="0 0 100 100" preserveAspectRatio="none">
    <circle cx="50" cy="50" r="40" fill="none" stroke="rgba(59, 130, 246, 0.1)" stroke-width="0.5"/>
    <circle cx="50" cy="50" r="30" fill="none" stroke="rgba(139, 92, 246, 0.1)" stroke-width="0.5"/>
    <circle cx="50" cy="50" r="20" fill="none" stroke="rgba(236, 72, 153, 0.1)" stroke-width="0.5"/>
  </svg>
  
  <svg class="svg-pattern pattern-2" viewBox="0 0 100 100" preserveAspectRatio="none">
    <rect x="10" y="10" width="80" height="80" fill="none" stroke="rgba(16, 185, 129, 0.1)" stroke-width="0.5" transform="rotate(45 50 50)"/>
    <rect x="20" y="20" width="60" height="60" fill="none" stroke="rgba(6, 182, 212, 0.1)" stroke-width="0.5" transform="rotate(45 50 50)"/>
  </svg>
  
  <svg class="svg-pattern pattern-3" viewBox="0 0 100 100" preserveAspectRatio="none">
    <polygon points="50,10 90,90 10,90" fill="none" stroke="rgba(249, 115, 22, 0.1)" stroke-width="0.5"/>
    <polygon points="50,20 80,80 20,80" fill="none" stroke="rgba(234, 179, 8, 0.1)" stroke-width="0.5"/>
  </svg>
  
  <!-- Floating shapes -->
  <div class="floating-shape shape-1"></div>
  <div class="floating-shape shape-2"></div>
  <div class="floating-shape shape-3"></div>
</div>

<style>
  .animated-background {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    overflow: hidden;
    background: linear-gradient(135deg, var(--bg-gradient-start) 0%, var(--bg-gradient-mid) 50%, var(--bg-gradient-end) 100%);
  }

  .animated-background::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: radial-gradient(rgba(148, 163, 184, 0.08) 1px, transparent 1px);
    background-size: 24px 24px;
    pointer-events: none;
  }

  :global(html:not(.dark)) .animated-background::before {
    background-image: radial-gradient(rgba(15, 23, 42, 0.05) 1.2px, transparent 1.2px);
  }

  .gradient-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    -webkit-filter: blur(60px);
    opacity: 0.5;
    animation: float 20s ease-in-out infinite;
    will-change: transform;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }

  .orb-1 {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, var(--accent-1) 0%, transparent 70%);
    top: -100px;
    left: -100px;
    animation-delay: 0s;
  }

  .orb-2 {
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, var(--accent-2) 0%, transparent 70%);
    top: 50%;
    right: -50px;
    animation-delay: -5s;
  }

  .orb-3 {
    width: 350px;
    height: 350px;
    background: radial-gradient(circle, var(--accent-3) 0%, transparent 70%);
    bottom: -100px;
    left: 30%;
    animation-delay: -10s;
  }

  .orb-4 {
    width: 250px;
    height: 250px;
    background: radial-gradient(circle, var(--accent-4) 0%, transparent 70%);
    top: 30%;
    left: 10%;
    animation-delay: -15s;
  }

  .svg-pattern {
    position: absolute;
    opacity: 0.3;
    animation: patternFloat 15s ease-in-out infinite;
    will-change: transform;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }

  .pattern-1 {
    width: 300px;
    height: 300px;
    top: 10%;
    right: 10%;
    animation-delay: -2s;
  }

  .pattern-2 {
    width: 250px;
    height: 250px;
    bottom: 20%;
    left: 5%;
    animation-delay: -7s;
  }

  .pattern-3 {
    width: 200px;
    height: 200px;
    top: 60%;
    right: 30%;
    animation-delay: -12s;
  }

  .floating-shape {
    position: absolute;
    opacity: 0.2;
    animation: shapeFloat 12s ease-in-out infinite;
    will-change: transform;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }

  .shape-1 {
    width: 100px;
    height: 100px;
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.3), rgba(139, 92, 246, 0.3));
    border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%;
    top: 20%;
    left: 15%;
    animation-delay: -3s;
  }

  .shape-2 {
    width: 80px;
    height: 80px;
    background: linear-gradient(135deg, rgba(16, 185, 129, 0.3), rgba(6, 182, 212, 0.3));
    border-radius: 50%;
    bottom: 30%;
    right: 20%;
    animation-delay: -8s;
  }

  .shape-3 {
    width: 120px;
    height: 120px;
    background: linear-gradient(135deg, rgba(236, 72, 153, 0.3), rgba(249, 115, 22, 0.3));
    border-radius: 20% 80% 20% 80% / 80% 20% 80% 20%;
    top: 50%;
    left: 50%;
    animation-delay: -13s;
  }

  @keyframes float {
    0%, 100% {
      transform: translate(0, 0) scale(1);
    }
    25% {
      transform: translate(50px, 50px) scale(1.1);
    }
    50% {
      transform: translate(0, 100px) scale(1);
    }
    75% {
      transform: translate(-50px, 50px) scale(0.9);
    }
  }

  @-webkit-keyframes float {
    0%, 100% {
      -webkit-transform: translate(0, 0) scale(1);
    }
    25% {
      -webkit-transform: translate(50px, 50px) scale(1.1);
    }
    50% {
      -webkit-transform: translate(0, 100px) scale(1);
    }
    75% {
      -webkit-transform: translate(-50px, 50px) scale(0.9);
    }
  }

  @keyframes patternFloat {
    0%, 100% {
      transform: translate(0, 0) rotate(0deg);
    }
    33% {
      transform: translate(30px, -30px) rotate(120deg);
    }
    66% {
      transform: translate(-30px, 30px) rotate(240deg);
    }
  }

  @-webkit-keyframes patternFloat {
    0%, 100% {
      -webkit-transform: translate(0, 0) rotate(0deg);
    }
    33% {
      -webkit-transform: translate(30px, -30px) rotate(120deg);
    }
    66% {
      -webkit-transform: translate(-30px, 30px) rotate(240deg);
    }
  }

  @keyframes shapeFloat {
    0%, 100% {
      transform: translate(0, 0) rotate(0deg);
    }
    50% {
      transform: translate(40px, -40px) rotate(180deg);
    }
  }

  @-webkit-keyframes shapeFloat {
    0%, 100% {
      -webkit-transform: translate(0, 0) rotate(0deg);
    }
    50% {
      -webkit-transform: translate(40px, -40px) rotate(180deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .gradient-orb,
    .svg-pattern,
    .floating-shape {
      animation: none;
    }
  }
</style>
