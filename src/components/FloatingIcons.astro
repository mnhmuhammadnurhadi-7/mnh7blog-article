---
/**
 * FloatingIcons - Icon-icon teknologi yang melayang di background
 * Diadaptasi dari React portfolio untuk Astro
 * Menggunakan SVG icons langsung (tanpa Lucide React dependency)
 */
interface Props {
  opacity?: number;
  iconSize?: number;
}

const { opacity = 0.6, iconSize = 32 } = Astro.props;

// Icon SVG sederhana untuk teknologi
const icons = [
  {
    name: 'code',
    svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>`,
    color: 'var(--accent-1)',
    size: iconSize,
  },
  {
    name: 'database',
    svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><ellipse cx="12" cy="5" rx="9" ry="3"></ellipse><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"></path><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"></path></svg>`,
    color: 'var(--accent-2)',
    size: iconSize * 1.3,
  },
  {
    name: 'cpu',
    svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="4" width="16" height="16" rx="2" ry="2"></rect><rect x="9" y="9" width="6" height="6"></rect><line x1="9" y1="1" x2="9" y2="4"></line><line x1="15" y1="1" x2="15" y2="4"></line><line x1="9" y1="20" x2="9" y2="23"></line><line x1="15" y1="20" x2="15" y2="23"></line><line x1="20" y1="9" x2="23" y2="9"></line><line x1="20" y1="14" x2="23" y2="14"></line><line x1="1" y1="9" x2="4" y2="9"></line><line x1="1" y1="14" x2="4" y2="14"></line></svg>`,
    color: 'var(--accent-3)',
    size: iconSize,
  },
  {
    name: 'cloud',
    svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"></path></svg>`,
    color: 'var(--accent-2)',
    size: iconSize * 1.2,
  },
  {
    name: 'zap',
    svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>`,
    color: 'var(--accent-3)',
    size: iconSize * 0.8,
  },
  {
    name: 'shield',
    svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>`,
    color: 'var(--accent-4)',
    size: iconSize,
  },
  {
    name: 'terminal',
    svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="4 17 10 11 4 5"></polyline><line x1="12" y1="19" x2="20" y2="19"></line></svg>`,
    color: 'var(--accent-3)',
    size: iconSize,
  },
  {
    name: 'git-branch',
    svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="6" y1="3" x2="6" y2="15"></line><circle cx="18" cy="6" r="3"></circle><circle cx="6" cy="18" r="3"></circle><path d="M18 9a9 9 0 0 1-9 9"></path></svg>`,
    color: 'var(--accent-2)',
    size: iconSize * 1.1,
  },
];

// Generate random positions and delays
const positionedIcons = icons.map((icon, index) => ({
  ...icon,
  top: Math.random() * 80 + 10,
  left: Math.random() * 80 + 10,
  delay: Math.random() * 10,
  animation: ['float-slow', 'float-slower', 'float-icon'][index % 3],
}));
---

<div class="floating-icons" style={`--opacity: ${opacity}`}>
  {positionedIcons.map((icon) => (
    <div
      class={`floating-icon ${icon.animation}`}
      style={{
        top: `${icon.top}%`,
        left: `${icon.left}%`,
        animationDelay: `${icon.delay}s`,
      }}
    >
      <div
        class="icon-wrapper"
        style={{
          width: `${icon.size}px`,
          height: `${icon.size}px`,
          color: icon.color,
        }}
        set:html={icon.svg}
      />
    </div>
  ))}
</div>

<style>
  .floating-icons {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    /* z-index 1 = di atas background (-1) tapi di bawah konten (10+) */
    z-index: 1;
  }

  .floating-icon {
    position: absolute;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: auto;
    cursor: pointer;
    will-change: transform;
    transform: translate3d(0, 0, 0);
    -webkit-transform: translate3d(0, 0, 0);
  }

  .icon-wrapper {
    /* Opacity lebih tinggi supaya terlihat jelas */
    opacity: 0.55;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.5s ease, filter 0.5s ease;
    filter: drop-shadow(0 0 10px currentColor);
    -webkit-filter: drop-shadow(0 0 10px currentColor);
  }

  .floating-icon:hover .icon-wrapper {
    opacity: 1;
    transform: scale(1.3) rotate(15deg);
    filter: drop-shadow(0 0 18px currentColor) drop-shadow(0 0 40px currentColor);
    -webkit-filter: drop-shadow(0 0 18px currentColor) drop-shadow(0 0 40px currentColor);
  }

  .float-slow {
    animation: floatSlow 12s ease-in-out infinite;
    -webkit-animation: floatSlow 12s ease-in-out infinite;
  }

  .float-slower {
    animation: floatSlower 16s ease-in-out infinite;
    -webkit-animation: floatSlower 16s ease-in-out infinite;
  }

  .float-icon {
    animation: floatIcon 20s ease-in-out infinite;
    -webkit-animation: floatIcon 20s ease-in-out infinite;
  }

  @keyframes floatSlow {
    0%, 100% {
      transform: translate3d(0, 0, 0) rotate(0deg);
    }
    50% {
      transform: translate3d(10px, -15px, 0) rotate(180deg);
    }
  }

  @-webkit-keyframes floatSlow {
    0%, 100% {
      -webkit-transform: translate3d(0, 0, 0) rotate(0deg);
    }
    50% {
      -webkit-transform: translate3d(10px, -15px, 0) rotate(180deg);
    }
  }

  @keyframes floatSlower {
    0%, 100% {
      transform: translate3d(0, 0, 0) scale(1);
    }
    50% {
      transform: translate3d(-15px, 15px, 0) scale(1.1);
    }
  }

  @-webkit-keyframes floatSlower {
    0%, 100% {
      -webkit-transform: translate3d(0, 0, 0) scale(1);
    }
    50% {
      -webkit-transform: translate3d(-15px, 15px, 0) scale(1.1);
    }
  }

  @keyframes floatIcon {
    0%, 100% {
      transform: translate3d(0, 0, 0) rotate(0deg) scale(1);
    }
    50% {
      transform: translate3d(0, -20px, 0) rotate(180deg) scale(1.2);
    }
  }

  @-webkit-keyframes floatIcon {
    0%, 100% {
      -webkit-transform: translate3d(0, 0, 0) rotate(0deg) scale(1);
    }
    50% {
      -webkit-transform: translate3d(0, -20px, 0) rotate(180deg) scale(1.2);
    }
  }
</style>
