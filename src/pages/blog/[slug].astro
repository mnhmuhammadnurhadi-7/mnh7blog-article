---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Artikel terkait (3 artikel selain yang sedang dibaca)
const relatedPosts = allPosts
  .filter((p) => p.slug !== post.slug)
  .slice(0, 3);

// Helper untuk format tanggal
function formatDate(date: Date) {
  return date.toLocaleDateString('id-ID', { 
    day: 'numeric', 
    month: 'short', 
    year: 'numeric' 
  });
}

// Helper untuk hitung reading time
function calculateReadingTime(content: string) {
  const wordsPerMinute = 200;
  const words = content.split(/\s+/).length;
  const minutes = Math.ceil(words / wordsPerMinute);
  return `${minutes} menit baca`;
}

// Ekstrak heading untuk TOC
const { remarkPlugin } = await post.render();
const headings = post.body?.matchAll(/^#{2,3}\s+(.+)$/gm) || [];
const tocItems = Array.from(headings).map((match) => ({
  text: match[1].trim(),
  level: match[0].startsWith('###') ? 3 : 2,
}));
---
<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={post.data.heroImage}
  canonicalUrl={post.data.canonicalUrl}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  isArticle={true}
>
  <!-- Progress bar -->
  <div id="progress-bar" class="progress-bar"></div>

  <article class="article-layout">
    <!-- Breadcrumb -->
    <nav class="breadcrumb">
      <a href="/">Beranda</a> / <a href="/blog">Artikel</a> / <span>{post.data.title}</span>
    </nav>

    <!-- Article header -->
    <header class="article-header">
      <h1 class="article-title">{post.data.title}</h1>
      
      <!-- Meta strip -->
      <div class="article-meta">
        <span class="meta-item">{formatDate(post.data.pubDate)}</span>
        <span class="meta-item">·</span>
        <span class="meta-item">{calculateReadingTime(post.body || '')}</span>
        {post.data.tags && post.data.tags.length > 0 && (
          <>
            <span class="meta-item">·</span>
            <span class="meta-item">Tag: {post.data.tags.join(', ')}</span>
          </>
        )}
      </div>

      {post.data.canonicalUrl && (
        <div class="canonical-info">
          <span class="canonical-text">canonical: {new URL(post.data.canonicalUrl).hostname} ↗</span>
        </div>
      )}

      {post.data.heroImage && (
        <img 
          src={post.data.heroImage} 
          alt={post.data.title} 
          class="hero-image"
        />
      )}
    </header>

    <!-- TOC (desktop sticky, mobile collapsible) -->
    {tocItems.length > 0 && (
      <aside class="toc-container glass-dark">
        <button 
          id="toc-toggle" 
          class="toc-toggle"
          aria-expanded="false"
          aria-controls="toc-list"
        >
          Daftar Isi
        </button>
        <nav id="toc-list" class="toc-list">
          <h4 class="toc-title">Daftar Isi</h4>
          <ul>
            {tocItems.map((item) => (
              <li class={`toc-level-${item.level}`}>
                <a href={`#${item.text.toLowerCase().replace(/\s+/g, '-')}`}>
                  {item.text}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </aside>
    )}

    <!-- Article content -->
    <div class="article-content glass-dark">
      <Content />
    </div>

    <!-- Canonical attribution -->
    {post.data.canonicalUrl && (
      <div class="attribution glass-dark">
        <p>
          Artikel ini pertama kali dipublikasikan di{' '}
          <a href={post.data.canonicalUrl} target="_blank" rel="noopener noreferrer">
            {new URL(post.data.canonicalUrl).hostname}
          </a>.
        </p>
      </div>
    )}

    <!-- Related articles -->
    {relatedPosts.length > 0 && (
      <section class="related-posts">
        <h3 class="related-title">Artikel Terkait</h3>
        <div class="related-grid">
          {relatedPosts.map((relatedPost) => (
            <a class="related-card glass-dark" href={`/blog/${relatedPost.slug}/`}>
              {relatedPost.data.heroImage && (
                <img 
                  src={relatedPost.data.heroImage} 
                  alt={relatedPost.data.title}
                  class="card-image"
                />
              )}
              <h4 class="related-card-title">{relatedPost.data.title}</h4>
              <div class="related-meta">
                <span class="meta-item">{formatDate(relatedPost.data.pubDate)}</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
  </article>
</BaseLayout>

<script>
  // Progress bar
  const progressBar = document.getElementById('progress-bar') as HTMLElement;
  if (progressBar) {
    window.addEventListener('scroll', () => {
      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const scrollPercent = (scrollTop / docHeight) * 100;
      progressBar.style.width = `${scrollPercent}%`;
    });
  }

  // TOC toggle untuk mobile
  const tocToggle = document.getElementById('toc-toggle') as HTMLButtonElement;
  const tocList = document.getElementById('toc-list') as HTMLElement;
  
  if (tocToggle && tocList) {
    tocToggle.addEventListener('click', () => {
      const isExpanded = tocToggle.getAttribute('aria-expanded') === 'true';
      tocToggle.setAttribute('aria-expanded', (!isExpanded).toString());
      tocList.classList.toggle('open');
    });
  }

  // Smooth scroll untuk TOC links
  document.querySelectorAll('.toc-list a').forEach((link) => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const targetId = link.getAttribute('href')?.slice(1);
      const targetElement = document.getElementById(targetId || '');
      if (targetElement) {
        targetElement.scrollIntoView({ behavior: 'smooth' });
      }
    });
  });
</script>

<style>
  .progress-bar {
    position: fixed;
    top: 0;
    left: 0;
    height: 2px;
    background: linear-gradient(90deg, #3b82f6, #8b5cf6);
    width: 0%;
    z-index: 1000;
    transition: width 50ms ease;
  }

  @media (prefers-reduced-motion: reduce) {
    .progress-bar {
      display: none;
    }
  }

  .article-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .breadcrumb {
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    color: #9ca3af;
    margin-bottom: 1.5rem;
  }

  .breadcrumb a {
    color: #9ca3af;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .breadcrumb a:hover {
    color: #8b5cf6;
  }

  .breadcrumb span {
    color: #f9fafb;
  }

  .article-header {
    margin-bottom: 2rem;
  }

  .article-title {
    font-family: 'Sora', sans-serif;
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, #3b82f6, #8b5cf6);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .article-meta {
    display: flex;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: #9ca3af;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .canonical-info {
    margin-top: 0.5rem;
  }

  .canonical-text {
    font-family: 'Inter', monospace;
    font-size: 0.8125rem;
    color: #f97316;
    font-weight: 500;
  }

  .hero-image {
    width: 100%;
    max-height: 400px;
    object-fit: cover;
    border-radius: 1rem;
    margin-top: 1.5rem;
  }

  .toc-container {
    display: none;
    padding: 1.5rem;
    border-radius: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .toc-toggle {
    display: none;
    width: 100%;
    padding: 0.875rem 1rem;
    background: rgba(26, 31, 58, 0.5);
    border: 1px solid rgba(139, 92, 246, 0.3);
    border-radius: 0.75rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    cursor: pointer;
    text-align: left;
    margin-bottom: 1rem;
    color: #f9fafb;
    transition: all 0.3s ease;
  }

  .toc-toggle:hover {
    border-color: #8b5cf6;
  }

  .toc-list {
    display: none;
  }

  .toc-list.open {
    display: block;
  }

  .toc-title {
    font-family: 'Sora', sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    color: #f9fafb;
  }

  .toc-list ul {
    list-style: none;
    padding: 0;
  }

  .toc-list li {
    margin-bottom: 0.5rem;
  }

  .toc-list a {
    color: #9ca3af;
    text-decoration: none;
    font-size: 0.875rem;
    display: block;
    padding: 0.25rem 0;
    transition: color 0.3s ease;
  }

  .toc-list a:hover {
    color: #8b5cf6;
  }

  .toc-level-3 {
    padding-left: 1rem;
  }

  .article-content {
    max-width: 680px;
    margin: 0 auto;
    padding: 2rem;
    border-radius: 1rem;
  }

  .article-content :global(h2) {
    font-family: 'Sora', sans-serif;
    font-size: 1.75rem;
    font-weight: 600;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    scroll-margin-top: 2rem;
    color: #f9fafb;
  }

  .article-content :global(h3) {
    font-family: 'Sora', sans-serif;
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    scroll-margin-top: 2rem;
    color: #f9fafb;
  }

  .article-content :global(p) {
    margin-bottom: 1.5rem;
    line-height: 1.7;
    color: #d1d5db;
  }

  .article-content :global(a) {
    color: #8b5cf6;
    text-decoration: underline;
    text-decoration-color: #8b5cf6;
  }

  .article-content :global(a:hover) {
    text-decoration-color: transparent;
  }

  .article-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 1rem;
    margin: 1.5rem 0;
  }

  .article-content :global(code) {
    background: rgba(26, 31, 58, 0.5);
    padding: 0.2rem 0.4rem;
    border-radius: 0.375rem;
    font-family: 'Inter', monospace;
    font-size: 0.875rem;
    color: #60a5fa;
  }

  .article-content :global(pre) {
    background: rgba(26, 31, 58, 0.5);
    padding: 1rem;
    border-radius: 0.75rem;
    overflow-x: auto;
    margin: 1.5rem 0;
    border: 1px solid rgba(139, 92, 246, 0.2);
  }

  .article-content :global(pre code) {
    background: none;
    padding: 0;
    color: #d1d5db;
  }

  .article-content :global(blockquote) {
    border-left: 3px solid #8b5cf6;
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: #9ca3af;
    font-style: italic;
    background: rgba(139, 92, 246, 0.1);
    padding: 1rem;
    border-radius: 0 0.5rem 0.5rem 0;
  }

  .attribution {
    margin-top: 3rem;
    padding: 1.5rem;
    border-radius: 1rem;
    border-left: 3px solid #f97316;
  }

  .attribution p {
    font-size: 0.875rem;
    color: #9ca3af;
    margin: 0;
  }

  .attribution a {
    color: #f97316;
    text-decoration: underline;
  }

  .related-posts {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .related-title {
    font-family: 'Sora', sans-serif;
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    background: linear-gradient(135deg, #3b82f6, #8b5cf6);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
  }

  .related-card {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    border-radius: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition: all 0.3s ease;
  }

  .related-card:hover {
    transform: translateY(-5px);
    border-color: rgba(139, 92, 246, 0.5);
    box-shadow: 0 10px 30px rgba(139, 92, 246, 0.2);
  }

  .related-card-title {
    font-family: 'Sora', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    margin: 0.75rem 0;
    color: #f9fafb;
    transition: color 0.3s ease;
  }

  .related-card:hover .related-card-title {
    color: #8b5cf6;
  }

  .related-meta {
    font-size: 0.875rem;
    color: #9ca3af;
  }

  .related-card .card-image {
    width: 100%;
    height: 150px;
    object-fit: cover;
    border-radius: 0.75rem;
  }

  @media (min-width: 1024px) {
    .article-layout {
      grid-template-columns: 250px 1fr;
      gap: 3rem;
    }

    .toc-container {
      display: block;
      position: sticky;
      top: 2rem;
      height: fit-content;
      max-height: calc(100vh - 4rem);
      overflow-y: auto;
    }

    .toc-toggle {
      display: none;
    }

    .toc-list {
      display: block;
    }

    .article-header {
      grid-column: 2;
    }

    .article-content {
      grid-column: 2;
    }

    .attribution {
      grid-column: 2;
    }

    .related-posts {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 768px) {
    .toc-container {
      display: block;
    }

    .toc-toggle {
      display: block;
    }

    .article-title {
      font-size: 2rem;
    }

    .hero-image {
      max-height: 300px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .related-card:hover {
      transform: none;
    }
  }
</style>
