---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Artikel Lainnya (3 artikel selain yang sedang dibaca)
const relatedPosts = allPosts
  .filter((p) => p.id !== post.id)
  .slice(0, 3);

// Helper untuk format tanggal
function formatDate(date: Date) {
  return date.toLocaleDateString('id-ID', { 
    day: 'numeric', 
    month: 'short', 
    year: 'numeric' 
  });
}

// Helper untuk hitung reading time
function calculateReadingTime(content: string) {
  const wordsPerMinute = 200;
  const words = content.split(/\s+/).length;
  const minutes = Math.ceil(words / wordsPerMinute);
  return `${minutes} menit baca`;
}

// Slugify function untuk membuat id dari heading text
function slugify(text: string): string {
  return text
    .toLowerCase()
    .trim()
    .replace(/[\s\u2000-\u206F\u2E00-\u2E7F\\'!"#$%&()*+,./:;<=>?@[\]^`{|}~]/g, '-')
    .replace(/-+/g, '-')
    .replace(/^-+|-+$/g, '');
}

// Ekstrak heading untuk TOC
const { remarkPlugin } = await render(post);
const headings = post.body?.matchAll(/^#{2,3}\s+(.+)$/gm) || [];
const tocItems = Array.from(headings).map((match) => ({
  text: match[1].trim(),
  level: match[0].startsWith('###') ? 3 : 2,
  id: slugify(match[1].trim()),
}));
---
<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={post.data.heroImage}
  canonicalUrl={post.data.canonicalUrl}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  isArticle={true}
>
  <!-- Progress bar -->
  <div id="progress-bar" class="progress-bar"></div>

  <article class="article-layout">
    <!-- Back button -->
    <a href="/blog" class="back-button">← Semua Artikel</a>

    <!-- Article header -->
    <header class="article-header">
      <h1 class="article-title">{post.data.title}</h1>
      
      <!-- Meta strip -->
      <div class="article-meta">
        <span class="meta-item">{formatDate(post.data.pubDate)}</span>
        <span class="meta-item">·</span>
        <span class="meta-item">{calculateReadingTime(post.body || '')}</span>
        {post.data.tags && post.data.tags.length > 0 && (
          <>
            <span class="meta-item">·</span>
            <span class="meta-item">Tag: {post.data.tags.join(', ')}</span>
          </>
        )}
      </div>

      {post.data.canonicalUrl && (
        <div class="canonical-info">
          <span class="canonical-text">canonical: {new URL(post.data.canonicalUrl).hostname} ↗</span>
        </div>
      )}

      <!-- TOC pill list -->
      {tocItems.length > 0 && (
        <div class="toc-pills">
          <span class="toc-label">Di halaman ini:</span>
          <div class="toc-pill-list">
            {tocItems.map((item) => (
              <a href={`#${item.id}`} class="toc-pill">{item.text}</a>
            ))}
          </div>
        </div>
      )}

      {post.data.heroImage && (
        <img 
          src={post.data.heroImage} 
          alt={post.data.title} 
          loading="eager"
          fetchpriority="high"
          width="1200"
          height="630"
          class="hero-image"
        />
      )}
    </header>


    <!-- Article content -->
    <div class="article-content glass-dark">
      <Content />
    </div>

    <!-- Canonical attribution -->
    {post.data.canonicalUrl && (
      <div class="attribution glass-dark">
        <p>
          Artikel ini pertama kali dipublikasikan di{' '}
          <a href={post.data.canonicalUrl} target="_blank" rel="noopener noreferrer">
            {new URL(post.data.canonicalUrl).hostname}
          </a>.
        </p>
      </div>
    )}

    <!-- Related articles -->
    {relatedPosts.length > 0 && (
      <section class="related-posts">
        <h3 class="related-title">Artikel Lainnya</h3>
        <div class="related-grid">
          {relatedPosts.map((relatedPost) => (
            <a class="related-card glass-dark" href={`/blog/${relatedPost.id}/`}>
              {relatedPost.data.heroImage && (
                <img 
                  src={relatedPost.data.heroImage} 
                  alt={relatedPost.data.title}
                  loading="lazy"
                  width="600"
                  height="300"
                  class="card-image"
                  style="display: block;"
                />
              )}
              <h4 class="related-card-title">{relatedPost.data.title}</h4>
              <div class="related-meta">
                <span class="meta-item">{formatDate(relatedPost.data.pubDate)}</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
  </article>
</BaseLayout>

<script>
  // Progress bar
  const progressBar = document.getElementById('progress-bar') as HTMLElement;
  if (progressBar) {
    window.addEventListener('scroll', () => {
      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const scrollPercent = (scrollTop / docHeight) * 100;
      progressBar.style.width = `${scrollPercent}%`;
    });
  }

  // Add IDs to headings automatically
  const articleContent = document.querySelector('.article-content');
  if (articleContent) {
    const headings = articleContent.querySelectorAll('h2, h3');
    headings.forEach((heading) => {
      const text = heading.textContent || '';
      const id = text
        .toLowerCase()
        .trim()
        .replace(/[\s\u2000-\u206F\u2E00-\u2E7F\\'!\"#$%&()*+,./:;<=>?@[\]^`{|}~]/g, '-')
        .replace(/-+/g, '-')
        .replace(/^-+|-+$/g, '');
      heading.id = id;
    });
  }

  // Smooth scroll untuk TOC links
  document.querySelectorAll('.toc-pill').forEach((link) => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const targetId = link.getAttribute('href')?.slice(1);
      const targetElement = document.getElementById(targetId || '');
      if (targetElement) {
        targetElement.scrollIntoView({ behavior: 'smooth' });
      }
    });
  });
</script>

<style>
  .progress-bar {
    position: fixed;
    top: 0;
    left: 0;
    height: 2px;
    background: linear-gradient(90deg, #3b82f6, #8b5cf6);
    width: 0%;
    z-index: 1000;
    transition: width 50ms ease;
  }

  @media (prefers-reduced-motion: reduce) {
    .progress-bar {
      display: none;
    }
  }

  .article-layout {
    max-width: 720px;
    margin: 0 auto;
    padding: 6rem 1.5rem 4rem;
  }

  @media (min-width: 768px) {
    .article-layout {
      padding: 6rem 2.5rem 4rem;
    }
  }

  .back-button {
    display: inline-flex;
    align-items: center;
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    color: var(--text-muted);
    text-decoration: none;
    margin-bottom: 1.5rem;
    transition: color 0.3s ease;
  }

  .back-button:hover {
    color: var(--text-link);
  }

  .article-header {
    margin-bottom: 2rem;
  }

  .article-title {
    font-family: 'Sora', sans-serif;
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, #3b82f6, #8b5cf6);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  :global(html:not(.dark)) .article-title {
    background: linear-gradient(135deg, #1d4ed8, #7c3aed);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .article-meta {
    display: flex;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .canonical-info {
    margin-top: 0.5rem;
  }

  .canonical-text {
    font-family: 'Inter', monospace;
    font-size: 0.8125rem;
    color: #f97316;
    font-weight: 500;
  }

  .toc-pills {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 1rem;
    padding-bottom: 1rem;
  }

  .toc-label {
    font-family: 'Inter', sans-serif;
    font-size: 0.8125rem;
    color: var(--text-muted);
    white-space: nowrap;
  }

  .toc-pill-list {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .toc-pill-list::-webkit-scrollbar {
    display: none;
  }

  .toc-pill {
    font-family: 'Inter', sans-serif;
    font-size: 0.8125rem;
    color: var(--text-muted);
    text-decoration: none;
    padding: 0.25rem 0.625rem;
    border: 1px solid var(--border-code);
    border-radius: 9999px;
    white-space: nowrap;
    transition: all 0.3s ease;
  }

  .toc-pill:hover {
    color: var(--text-link);
    border-color: var(--text-link);
    background: rgba(124, 58, 237, 0.1);
  }

  .hero-image {
    width: 100%;
    max-height: 400px;
    object-fit: cover;
    border-radius: 1rem;
    margin-top: 1.5rem;
    display: block;
  }


  .article-content {
    padding: 2rem;
    border-radius: 1rem;
    background: var(--bg-card);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
  }

  .article-content :global(h2) {
    font-family: 'Sora', sans-serif;
    font-size: 1.75rem;
    font-weight: 600;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    scroll-margin-top: 2rem;
    color: var(--text-primary);
  }

  .article-content :global(h3) {
    font-family: 'Sora', sans-serif;
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    scroll-margin-top: 2rem;
    color: var(--text-primary);
  }

  .article-content :global(p) {
    margin-bottom: 1.5rem;
    line-height: 1.7;
    color: var(--text-secondary);
  }

  .article-content :global(a) {
    color: var(--text-link);
    text-decoration: underline;
    text-decoration-color: var(--text-link);
  }

  .article-content :global(a:hover) {
    text-decoration-color: transparent;
  }

  .article-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 1rem;
    margin: 1.5rem 0;
  }

  .article-content :global(code) {
    background: var(--bg-code);
    padding: 0.2rem 0.4rem;
    border-radius: 0.375rem;
    font-family: 'Inter', monospace;
    font-size: 0.875rem;
    color: var(--text-code);
  }

  .article-content :global(pre) {
    background: var(--bg-code-block);
    padding: 1rem;
    border-radius: 0.75rem;
    overflow-x: auto;
    margin: 1.5rem 0;
    border: 1px solid var(--border-code);
  }

  .article-content :global(pre code) {
    background: none;
    padding: 0;
    color: var(--text-primary);
  }

  .article-content :global(blockquote) {
    border-left: 3px solid var(--text-link);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--text-muted);
    font-style: italic;
    background: var(--bg-blockquote);
    padding: 1rem;
    border-radius: 0 0.5rem 0.5rem 0;
  }

  .article-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    border-radius: 0.5rem;
    overflow: hidden;
    border: 1px solid var(--border-table);
  }

  .article-content :global(th) {
    background: var(--bg-table-header);
    font-weight: 600;
    padding: 0.75rem 1rem;
    text-align: left;
    border-bottom: 1px solid var(--border-table);
    border-right: 1px solid var(--border-table);
    color: var(--text-primary);
  }

  .article-content :global(th:last-child) {
    border-right: none;
  }

  .article-content :global(td) {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border-table);
    border-right: 1px solid var(--border-table);
    color: var(--text-secondary);
  }

  .article-content :global(td:last-child) {
    border-right: none;
  }

  .article-content :global(tr:last-child td) {
    border-bottom: none;
  }

  .article-content :global(tbody tr:nth-child(even)) {
    background: var(--bg-table-row-even);
  }

  .article-content :global(table) {
    display: block;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  @media (min-width: 768px) {
    .article-content :global(table) {
      display: table;
    }
  }

  .attribution {
    margin-top: 3rem;
    padding: 1.5rem;
    border-radius: 1rem;
    border-left: 3px solid var(--text-canonical);
    background: var(--bg-card);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
  }

  .attribution p {
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin: 0;
  }

  .attribution a {
    color: var(--text-canonical);
    text-decoration: underline;
  }

  .related-posts {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .related-title {
    font-family: 'Sora', sans-serif;
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    background: linear-gradient(135deg, #3b82f6, #8b5cf6);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
  }

  .related-card {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    border-radius: 1rem;
    border: 1px solid var(--border-code);
    transition: all 0.3s ease;
    background: var(--bg-card);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .related-card:hover {
    transform: translateY(-5px);
    border-color: rgba(139, 92, 246, 0.5);
    box-shadow: 0 10px 30px rgba(139, 92, 246, 0.2);
  }

  .related-card-title {
    font-family: 'Sora', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    margin: 0.75rem 0;
    color: var(--text-primary);
    transition: color 0.3s ease;
  }

  .related-card:hover .related-card-title {
    color: var(--text-link-hover);
  }

  .related-meta {
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .related-card .card-image {
    width: 100%;
    height: 150px;
    object-fit: cover;
    border-radius: 0.75rem;
  }


  @media (max-width: 768px) {
    .article-title {
      font-size: 2rem;
    }

    .hero-image {
      max-height: 300px;
    }

    .toc-pill-list {
      flex-wrap: nowrap;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .related-card:hover {
      transform: none;
    }
  }
</style>
