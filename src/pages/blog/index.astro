---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// kumpulin semua tahun unik buat filter
const years = [...new Set(posts.map((p) => p.data.pubDate.getFullYear()))].sort((a, b) => b - a);

// Helper untuk format tanggal
function formatDate(date: Date) {
  return date.toLocaleDateString('id-ID', { 
    day: 'numeric', 
    month: 'short', 
    year: 'numeric' 
  });
}

// Helper untuk hitung reading time
function calculateReadingTime(content: string) {
  const wordsPerMinute = 200;
  const words = content.split(/\s+/).length;
  const minutes = Math.ceil(words / wordsPerMinute);
  return `${minutes} menit baca`;
}
---
<BaseLayout title="Semua Artikel" description="Kumpulan tulisan Muhammad Nur Hadi seputar SEO, teknologi, dan pengembangan diri.">
  <div class="page-header">
    <h1 class="page-title">Semua Artikel</h1>
    
    <div class="search-filter">
      <input
        type="text"
        id="search"
        placeholder="Cari artikel..."
        aria-label="Cari artikel"
        class="search-input glass-dark"
      />

      <div id="year-filter" class="year-chips">
        <button data-year="all" class="chip active">Semua</button>
        {years.map((y) => (
          <button data-year={y} class="chip">{y}</button>
        ))}
      </div>
    </div>
  </div>

  <div id="post-grid" class="posts-grid">
    {posts.map((post) => (
      <a
        class="post-card glass-dark"
        href={`/blog/${post.id}/`}
        data-title={post.data.title.toLowerCase()}
        data-year={post.data.pubDate.getFullYear()}
      >
        {post.data.heroImage && (
          <img 
            src={post.data.heroImage} 
            alt={post.data.title} 
            loading="lazy"
            width="800"
            height="400"
            class="card-image"
            style="display: block;"
          />
        )}
        <h3 class="post-title">{post.data.title}</h3>
        <div class="post-meta">
          <span class="meta-item">{formatDate(post.data.pubDate)}</span>
          <span class="meta-item">·</span>
          <span class="meta-item">{calculateReadingTime(post.body || '')}</span>
        </div>
        <p class="post-excerpt">{post.data.description}</p>
        {post.data.tags && post.data.tags.length > 0 && (
          <div class="post-tags">
            {post.data.tags.slice(0, 3).map((tag) => (
              <span class="post-tag">{tag}</span>
            ))}
          </div>
        )}
      </a>
    ))}
  </div>

  <p id="no-results" class="no-results">Nggak ada artikel yang cocok.</p>
</BaseLayout>

<script>
  const searchInput = document.getElementById('search') as HTMLInputElement;
  const yearButtons = document.querySelectorAll<HTMLButtonElement>('#year-filter .chip');
  const cards = document.querySelectorAll<HTMLAnchorElement>('.post-card');
  const noResults = document.getElementById('no-results')!;

  let activeYear = 'all';

  function applyFilter() {
    const query = searchInput.value.toLowerCase();
    let visibleCount = 0;

    cards.forEach((card) => {
      const matchesSearch = card.dataset.title!.includes(query);
      const matchesYear = activeYear === 'all' || card.dataset.year === activeYear;
      const show = matchesSearch && matchesYear;
      (card as HTMLElement).style.display = show ? 'flex' : 'none';
      if (show) visibleCount++;
    });

    noResults.style.display = visibleCount > 0 ? 'none' : 'block';
  }

  searchInput.addEventListener('input', applyFilter);

  yearButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      yearButtons.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      activeYear = btn.dataset.year!;
      applyFilter();
    });
  });
</script>

<style>
  .page-header {
    padding: 6rem 1.5rem 2rem; /* pt-24 px-6 pb-8 */
    margin-bottom: 0;
  }

  @media (min-width: 768px) {
    .page-header {
      padding: 6rem 2.5rem 2rem; /* pt-24 md:px-10 pb-8 */
    }
  }

  .page-title {
    font-family: 'Sora', sans-serif;
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    background: linear-gradient(135deg, #3b82f6, #10b981);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .search-filter {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .search-input {
    padding: 0.875rem 1.25rem;
    border: 1px solid var(--border-purple);
    border-radius: 0.75rem;
    font-size: 1rem;
    font-family: 'Inter', sans-serif;
    max-width: 400px;
    background: var(--bg-input);
    color: var(--text-primary);
    transition: all 0.3s ease;
  }

  .search-input::placeholder {
    color: var(--text-secondary);
  }

  .search-input:focus {
    outline: none;
    border-color: var(--accent-2);
    box-shadow: 0 0 0 3px rgba(139, 92, 246, 0.12);
  }

  .year-chips {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .chip {
    padding: 0.5rem 1rem;
    border: 1px solid var(--border-purple);
    border-radius: 9999px;
    background: var(--bg-chip);
    color: var(--text-secondary);
    font-size: 0.875rem;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .chip:hover {
    border-color: var(--accent-2);
    color: var(--text-primary);
  }

  .chip.active {
    background: linear-gradient(135deg, var(--accent-1), var(--accent-2));
    color: var(--text-primary);
    border-color: transparent;
  }

  .chip:focus {
    outline: 2px solid var(--accent-2);
    outline-offset: 2px;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    padding: 0 1.5rem 4rem; /* px-6 pb-16 */
  }

  @media (min-width: 768px) {
    .posts-grid {
      padding: 0 2.5rem 4rem; /* md:px-10 pb-16 */
    }
  }

  .post-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    padding: 1.5rem;
    border-radius: 1rem;
    transition: all 0.3s ease;
    border: 1px solid var(--border-subtle);
  }

  .post-card:hover {
    transform: translateY(-5px);
    border-color: rgba(139, 92, 246, 0.28);
    box-shadow: 0 10px 30px rgba(139, 92, 246, 0.14);
  }

  .card-image {
    width: 100%;
    height: 200px;
    object-fit: cover;
    border-radius: 0.75rem;
    margin-bottom: 1rem;
  }

  .post-title {
    font-family: 'Sora', sans-serif;
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0.75rem 0;
    color: var(--text-primary);
    transition: color 0.3s ease;
    line-height: 1.4;
  }

  .post-card:hover .post-title {
    color: #8b5cf6;
  }

  .post-meta {
    display: flex;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--text-muted-dark);
    margin-bottom: 0.75rem;
  }

  .post-excerpt {
    color: var(--text-muted-dark);
    font-size: 0.9375rem;
    line-height: 1.6;
    margin-bottom: 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: auto;
  }

  .post-tag {
    padding: 0.25rem 0.75rem;
    background: rgba(59, 130, 246, 0.2);
    border: 1px solid rgba(59, 130, 246, 0.3);
    border-radius: 9999px;
    font-size: 0.75rem;
    color: #60a5fa;
  }

  .no-results {
    text-align: center;
    color: var(--text-muted-dark);
    font-size: 1rem;
    padding: 2rem;
    display: none;
  }

  @media (max-width: 1024px) {
    .posts-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .posts-grid {
      grid-template-columns: 1fr;
    }

    .search-input {
      max-width: 100%;
    }

    .page-title {
      font-size: 2rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .post-card:hover {
      transform: none;
    }
  }
</style>
