---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

// Helper untuk format tanggal
function formatDate(date: Date) {
  return date.toLocaleDateString('id-ID', { 
    day: 'numeric', 
    month: 'short', 
    year: 'numeric' 
  });
}

// Helper untuk hitung reading time (estimasi 200 kata per menit)
function calculateReadingTime(content: string) {
  const wordsPerMinute = 200;
  const words = content.split(/\s+/).length;
  const minutes = Math.ceil(words / wordsPerMinute);
  return `${minutes} menit baca`;
}
---
<BaseLayout
  title="Home"
  description="Portofolio dan tulisan Muhammad Nur Hadi seputar SEO, project coordination, dan digital product."
>
  <section class="hero">
    <div class="hero-content">
      <h1 class="hero-title">
        <span class="gradient-text">Halo, saya</span>
        <br />
        <span class="gradient-text">Muhammad Nur Hadi</span>
      </h1>
      <p class="hero-subtitle">
        Project coordination, system analysis, dan SEO specialist. 
        Berbagi tulisan seputar strategi digital.
      </p>
      <div class="hero-tags">
        <span class="hero-tag neon-blue">SEO Specialist</span>
        <span class="hero-tag neon-purple">Project Coordinator</span>
        <span class="hero-tag neon-emerald">Technical Writer</span>
      </div>
      <div class="hero-actions">
        <a href="/blog" class="btn-primary">Baca Artikel</a>
        <a href="https://mnurhadi-porto.vercel.app/" target="_blank" rel="noopener" class="btn-secondary">
          Lihat Portfolio
        </a>
      </div>
    </div>
  </section>

  <section class="latest-posts">
    <div class="section-header">
      <h2 class="section-title">Artikel Terbaru</h2>
      <a href="/blog" class="btn-link">Lihat semua →</a>
    </div>
    
    <div class="posts-grid">
      {posts.map((post) => (
        <a class="post-card glass-dark" href={`/blog/${post.id}/`}>
          {post.data.heroImage && (
            <img 
              src={post.data.heroImage} 
              alt={post.data.title} 
              loading="lazy"
              class="card-image"
            />
          )}
          <h3 class="post-title">{post.data.title}</h3>
          <div class="post-meta">
            <span class="meta-item">{formatDate(post.data.pubDate)}</span>
            <span class="meta-item">·</span>
            <span class="meta-item">{calculateReadingTime(post.body || '')}</span>
          </div>
          <p class="post-excerpt">{post.data.description}</p>
          {post.data.tags && post.data.tags.length > 0 && (
            <div class="post-tags">
              {post.data.tags.slice(0, 3).map((tag) => (
                <span class="post-tag">{tag}</span>
              ))}
            </div>
          )}
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    min-height: calc(100vh - 4rem);
    display: flex;
    align-items: center;
    justify-content: flex-start;
    padding: 6rem 1.5rem; /* py-24 px-6 */
  }

  @media (min-width: 768px) {
    .hero {
      padding: 6rem 2.5rem; /* py-24 md:px-10 */
    }
  }

  .hero-content {
    max-width: 56rem; /* max-w-4xl */
    width: 100%;
    text-align: left;
    animation: heroEnter 0.9s cubic-bezier(0.4, 0, 0.2, 1) both;
    animation-delay: 0.2s;
  }

  @keyframes heroEnter {
    from { opacity: 0; transform: translateY(40px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .hero-title {
    font-family: 'Sora', sans-serif;
    font-size: 4rem;
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--accent-1), var(--accent-2), var(--accent-4));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: gradientShift 5s ease-in-out infinite;
  }

  @keyframes gradientShift {
    0%, 100% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--text-secondary);
    margin-bottom: 2rem;
    line-height: 1.6;
    animation: heroEnter 0.9s cubic-bezier(0.4, 0, 0.2, 1) both;
    animation-delay: 0.45s;
  }

  .hero-tags {
    display: flex;
    gap: 1rem;
    justify-content: flex-start;
    flex-wrap: wrap;
    margin-bottom: 2rem;
    animation: heroEnter 0.9s cubic-bezier(0.4, 0, 0.2, 1) both;
    animation-delay: 0.6s;
  }

  .hero-tag {
    padding: 0.5rem 1.125rem;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-primary);
    animation: tagFloat 6s ease-in-out infinite;
    cursor: default;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .hero-tag:hover {
    transform: translateY(-4px) scale(1.06);
  }

  .neon-blue {
    background: rgba(59, 130, 246, 0.12);
    border: 1px solid rgba(59, 130, 246, 0.28);
    box-shadow: 0 0 20px rgba(59, 130, 246, 0.18);
  }

  .neon-purple {
    background: rgba(139, 92, 246, 0.12);
    border: 1px solid rgba(139, 92, 246, 0.28);
    box-shadow: 0 0 20px rgba(139, 92, 246, 0.18);
    animation-delay: -2s;
  }

  .neon-emerald {
    background: rgba(16, 185, 129, 0.12);
    border: 1px solid rgba(16, 185, 129, 0.28);
    box-shadow: 0 0 20px rgba(16, 185, 129, 0.18);
    animation-delay: -4s;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: flex-start;
    flex-wrap: wrap;
    animation: heroEnter 0.9s cubic-bezier(0.4, 0, 0.2, 1) both;
    animation-delay: 0.75s;
  }

  .btn-primary {
    padding: 0.875rem 2rem;
    background: linear-gradient(135deg, var(--accent-1), var(--accent-2));
    background-size: 200% 200%;
    color: #ffffff;
    text-decoration: none;
    border-radius: 9999px;
    font-weight: 600;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 4px 15px rgba(59, 130, 246, 0.3);
    position: relative;
    overflow: hidden;
  }

  .btn-primary::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(135deg, var(--accent-2), var(--accent-4));
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .btn-primary:hover::before {
    opacity: 1;
  }

  .btn-primary:hover {
    transform: translateY(-3px) scale(1.04);
    box-shadow: 0 8px 28px rgba(59, 130, 246, 0.55);
  }

  .btn-primary:active {
    transform: translateY(-1px) scale(1.01);
  }

  .btn-secondary {
    padding: 0.875rem 2rem;
    background: transparent;
    color: var(--text-primary);
    text-decoration: none;
    border: 2px solid rgba(139, 92, 246, 0.35);
    border-radius: 9999px;
    font-weight: 600;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }

  .btn-secondary::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(circle at center, rgba(139, 92, 246, 0.15), transparent 70%);
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .btn-secondary:hover::before {
    opacity: 1;
  }

  .btn-secondary:hover {
    border-color: #8b5cf6;
    transform: translateY(-3px) scale(1.04);
    box-shadow: 0 0 20px rgba(139, 92, 246, 0.3);
  }

  .btn-secondary:active {
    transform: translateY(-1px) scale(1.01);
  }

  .latest-posts {
    padding: 4rem 0;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    padding: 0 1.5rem;
  }

  @media (min-width: 768px) {
    .section-header {
      padding: 0 2.5rem;
    }
  }

  .section-title {
    font-family: 'Sora', sans-serif;
    font-size: 2rem;
    font-weight: 700;
    background: linear-gradient(135deg, var(--accent-1), var(--accent-2));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .btn-link {
    color: var(--text-secondary);
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
    position: relative;
    padding-bottom: 2px;
  }

  .btn-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    border-radius: 9999px;
    background: linear-gradient(90deg, var(--accent-2), var(--accent-4));
    transition: width 0.3s ease;
  }

  .btn-link:hover {
    color: var(--accent-4);
  }

  .btn-link:hover::after {
    width: 100%;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    padding: 0 1.5rem 4rem;
  }

  @media (min-width: 768px) {
    .posts-grid {
      padding: 0 2.5rem 4rem;
    }
  }

  .post-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    padding: 1.5rem;
    border-radius: 1rem;
    transition: all 0.3s ease;
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  .post-card:hover {
    transform: translateY(-5px);
    border-color: rgba(139, 92, 246, 0.28);
    box-shadow: 0 10px 30px rgba(139, 92, 246, 0.14);
  }

  .card-image {
    width: 100%;
    height: 200px;
    object-fit: cover;
    border-radius: 0.75rem;
    margin-bottom: 1rem;
  }

  .post-title {
    font-family: 'Sora', sans-serif;
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0.75rem 0;
    color: #f9fafb;
    transition: color 0.3s ease;
    line-height: 1.4;
  }

  .post-card:hover .post-title {
    color: #8b5cf6;
  }

  .post-meta {
    display: flex;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: #9ca3af;
    margin-bottom: 0.75rem;
  }

  .post-excerpt {
    color: #9ca3af;
    font-size: 0.9375rem;
    line-height: 1.6;
    margin-bottom: 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: auto;
  }

  .post-tag {
    padding: 0.25rem 0.75rem;
    background: rgba(59, 130, 246, 0.2);
    border: 1px solid rgba(59, 130, 246, 0.3);
    border-radius: 9999px;
    font-size: 0.75rem;
    color: #60a5fa;
  }


  @media (max-width: 1024px) {
    .posts-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .hero-title {
      font-size: 2.5rem;
    }

    .hero-subtitle {
      font-size: 1rem;
    }

    .hero-actions {
      flex-direction: column;
      align-items: center;
    }

    .section-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }

    .posts-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .gradient-text,
    .hero-tag {
      animation: none;
    }

    .post-card:hover {
      transform: none;
    }
  }
</style>
