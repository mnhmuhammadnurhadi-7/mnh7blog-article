---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

// Helper untuk format tanggal
function formatDate(date: Date) {
  return date.toLocaleDateString('id-ID', { 
    day: 'numeric', 
    month: 'short', 
    year: 'numeric' 
  });
}

// Helper untuk hitung reading time (estimasi 200 kata per menit)
function calculateReadingTime(content: string) {
  const wordsPerMinute = 200;
  const words = content.split(/\s+/).length;
  const minutes = Math.ceil(words / wordsPerMinute);
  return `${minutes} menit baca`;
}
---
<BaseLayout
  title="Home"
  description="Portofolio dan tulisan Muhammad Nur Hadi seputar SEO, project coordination, dan digital product."
>
  <section class="hero">
    <h1>Halo, saya Muhammad Nur Hadi</h1>
    <p class="positioning">Project coordination, system analysis, dan SEO specialist. Berbagi tulisan seputar strategi digital.</p>
    <div class="meta-strip">// SEO Specialist · Project Coordinator · Technical Writer</div>
  </section>

  <section class="latest-posts">
    <div class="section-header">
      <h2>Artikel Terbaru</h2>
      <a href="/blog" class="btn-primary">Lihat semua →</a>
    </div>
    
    <div class="posts-grid">
      {posts.map((post) => (
        <a class="card post-card" href={`/blog/${post.slug}/`}>
          {post.data.heroImage && (
            <img 
              src={post.data.heroImage} 
              alt={post.data.title} 
              loading="lazy"
              class="card-image"
            />
          )}
          <h3>{post.data.title}</h3>
          <div class="meta-strip">
            // {formatDate(post.data.pubDate)} · {calculateReadingTime(post.body || '')}
          </div>
          <p class="excerpt">{post.data.description}</p>
          {post.data.tags && post.data.tags.length > 0 && (
            <div class="tags">
              {post.data.tags.slice(0, 3).map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )}
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 4rem 0;
    max-width: 800px;
  }

  .hero h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    line-height: 1.15;
  }

  .positioning {
    font-size: 1.125rem;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  .meta-strip {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.8125rem;
    color: var(--text-secondary);
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .latest-posts {
    margin-top: 4rem;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }

  .section-header h2 {
    font-size: 1.75rem;
    font-weight: 600;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .post-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    transition: border-color 150ms ease;
  }

  .post-card:hover {
    border-color: var(--accent);
  }

  .post-card:hover h3 {
    color: var(--accent);
  }

  .post-card h3 {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 1rem 0;
    color: var(--text-primary);
    transition: color 150ms ease;
  }

  .card-image {
    width: 100%;
    height: 200px;
    object-fit: cover;
    border-radius: 4px;
    margin-bottom: 1rem;
  }

  .excerpt {
    color: var(--text-secondary);
    font-size: 0.9375rem;
    line-height: 1.6;
    margin-bottom: 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: auto;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 2rem 0;
    }

    .hero h1 {
      font-size: 2rem;
    }

    .section-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }

    .posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
