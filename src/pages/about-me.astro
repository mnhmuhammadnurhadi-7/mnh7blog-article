---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="About Me"
  description="Tentang Muhammad Nur Hadi, project coordinator, system analyst, dan SEO specialist yang membangun produk digital terstruktur dan mudah ditemukan di hasil pencarian."
>
  <section class="about-hero">
    <p class="meta-strip">About Me</p>
    <h1>Skills & Capabilities</h1>
  </section>

  <section class="section-section">
    <div class="skills-grid">
      <div class="skill-card">
        <h3>Project & Coordination</h3>
        <div class="skill-tags">
          <span class="skill-tag">Project Management</span>
          <span class="skill-tag">System Flow Design</span>
          <span class="skill-tag">Cross-team Leadership</span>
          <span class="skill-tag">Stakeholder Reporting</span>
          <span class="skill-tag">Task Delegation</span>
        </div>
      </div>
      <div class="skill-card">
        <h3>System Analysis</h3>
        <div class="skill-tags">
          <span class="skill-tag">Workflow Design</span>
          <span class="skill-tag">Process Documentation</span>
          <span class="skill-tag">Architecture Planning</span>
          <span class="skill-tag">Requirements Analysis</span>
        </div>
      </div>
      <div class="skill-card">
        <h3>SEO & Content</h3>
        <div class="skill-tags">
          <span class="skill-tag">SEO Writing</span>
          <span class="skill-tag">Keyword Research</span>
          <span class="skill-tag">Google Page 1 Ranking</span>
          <span class="skill-tag">Article Publishing</span>
          <span class="skill-tag">Content Strategy</span>
        </div>
      </div>
      <div class="skill-card">
        <h3>Technical</h3>
        <div class="skill-tags">
          <span class="skill-tag">React</span>
          <span class="skill-tag">Laravel</span>
          <span class="skill-tag">MySQL</span>
          <span class="skill-tag">Figma</span>
          <span class="skill-tag">REST API</span>
          <span class="skill-tag">CMS</span>
          <span class="skill-tag">n8n</span>
          <span class="skill-tag">Ollama</span>
        </div>
      </div>
      <div class="skill-card">
        <h3>Deployment & Tools</h3>
        <div class="skill-tags">
          <span class="skill-tag">Vercel</span>
          <span class="skill-tag">Northflank</span>
          <span class="skill-tag">Aiven</span>
          <span class="skill-tag">Git</span>
          <span class="skill-tag">Google Workspace</span>
          <span class="skill-tag">Microsoft Office</span>
        </div>
      </div>
      <div class="skill-card">
        <h3>Languages</h3>
        <div class="skill-tags">
          <span class="skill-tag">Indonesian (Native)</span>
          <span class="skill-tag">English (Intermediate)</span>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about-hero {
    padding: 6rem 1.5rem 2rem; /* pt-24 px-6 pb-8 */
    margin-bottom: 4rem;
  }

  @media (min-width: 768px) {
    .about-hero {
      padding: 6rem 2.5rem 2rem; /* pt-24 md:px-10 pb-8 */
    }
  }

  .meta-strip {
    font-size: 0.75rem; /* text-xs */
    font-weight: 700; /* font-bold */
    letter-spacing: 0.2em; /* tracking-[0.2em] */
    text-transform: uppercase;
    margin-bottom: 0.75rem;
    color: var(--text-secondary);
  }

  .about-hero h1 {
    font-family: 'Sora', sans-serif;
    font-size: 2.25rem; /* text-4xl */
    font-weight: 800; /* font-extrabold */
    letter-spacing: -0.025em; /* tracking-tight */
    margin: 0;
    color: var(--text-primary);
  }

  @media (min-width: 768px) {
    .about-hero h1 {
      font-size: 3rem; /* md:text-5xl */
    }
  }

  .section-section {
    padding: 0 1.5rem; /* px-6 */
    margin-bottom: 4rem;
  }

  @media (min-width: 768px) {
    .section-section {
      padding: 0 2.5rem; /* md:px-10 */
    }
  }

  .skills-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem; /* gap-6 */
  }

  @media (min-width: 768px) {
    .skills-grid {
      grid-template-columns: repeat(2, 1fr); /* md:grid-cols-2 */
    }
  }

  @media (min-width: 1024px) {
    .skills-grid {
      grid-template-columns: repeat(3, 1fr); /* lg:grid-cols-3 */
    }
  }

  .skill-card {
    background-color: #18181b; /* bg-zinc-900 = dark bgSecondary */
    border: 1px solid #27272a; /* border-zinc-800 */
    border-radius: 1rem; /* rounded-2xl */
    padding: 1.75rem; /* p-7 */
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  .skill-card:hover {
    transform: translateY(-4px) scale(1.03);
    border-color: #3b82f6; /* hover:border-blue-400/50 */
  }

  :global(html:not(.dark)) .skill-card {
    background-color: #f4f4f5; /* bg-zinc-100 = light bgSecondary */
    border-color: #e4e4e7; /* border-zinc-200 */
  }

  :global(html:not(.dark)) .skill-card:hover {
    border-color: #3b82f6;
  }

  .skill-card h3 {
    font-size: 0.875rem; /* text-sm */
    font-weight: 900; /* font-black */
    letter-spacing: 0.05em; /* tracking-wide */
    margin-bottom: 1.25rem; /* mb-5 */
    color: var(--text-primary);
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem; /* gap-2 */
  }

  .skill-tag {
    background: linear-gradient(to right, rgba(59, 130, 246, 0.2), rgba(16, 185, 129, 0.2)); /* bg-gradient-to-r from-blue-500/20 to-emerald-500/20 */
    color: var(--text-secondary);
    font-size: 0.75rem; /* text-xs */
    font-weight: 500; /* font-medium */
    padding: 0.375rem 0.75rem; /* px-3 py-1.5 */
    border-radius: 9999px;
    border: 1px solid #27272a; /* border-zinc-800 */
    transition: border-color 0.3s ease;
  }

  .skill-tag:hover {
    border-color: rgba(59, 130, 246, 0.5); /* hover:border-blue-400/50 */
  }

  :global(html:not(.dark)) .skill-tag {
    border-color: #e4e4e7; /* border-zinc-200 */
  }

  :global(html:not(.dark)) .skill-tag:hover {
    border-color: rgba(59, 130, 246, 0.5);
  }
</style>
